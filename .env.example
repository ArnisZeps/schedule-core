# Neon connection string for the dev branch
DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require

# Separate Neon branch for integration tests — never point at production
TEST_DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require

# Minimum 32 bytes of random entropy — never commit the real value
JWT_SECRET=change-me-to-a-random-32-byte-string

# Obsidian local REST API (optional — only needed for /obsidian-* skills)
OBSIDIAN_HOST=http://localhost:27123
OBSIDIAN_API_KEY=
