{
  "name": "@schedule-core/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --clear-screen=false --env-file .env src/index.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "pretest": "pnpm --filter @schedule-core/db build",
    "test": "vitest run",
    "seed": "tsx --env-file .env scripts/seed-dev.ts"
  },
  "type": "module",
  "dependencies": {
    "@schedule-core/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^16.6.1",
    "supertest": "^7.2.2",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
